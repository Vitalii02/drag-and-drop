<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
</head>
<body>
<form name="search">
    <input  id="valueText" type="text" name="key" placeholder="Введите слово">
    <button type="button" name="print" value="Печать" >Печать</button>
</form>
<div id="printBlock"></div>
<script>
    let keyBox = document.search.key
    function onchange(e){
        let printBlock = document.getElementById("printBlock")
        let val = e.target.value
    }
    keyBox.addEventListener("change", onchange)


    let printBlock = document.getElementById("printBlock")
    printBlock.onmousedown = function(event) {

        let shiftX = event.clientX - printBlock.getBoundingClientRect().left
        let shiftY = event.clientY - printBlock.getBoundingClientRect().top

        printBlock.style.position = 'absolute'

        document.body.append(printBlock)

        moveAt(event.pageX, event.pageY)

        function moveAt(pageX, pageY) {
            printBlock.style.left = pageX - shiftX + 'px'
            printBlock.style.top = pageY - shiftY + 'px'
        }
        function onMouseMove(event) {
            moveAt(event.pageX, event.pageY)
        }
        document.addEventListener('mousemove', onMouseMove)

        printBlock.onmouseup = function() {
            document.removeEventListener('mousemove', onMouseMove)
            printBlock.onmouseup = null
        }
    }
    printBlock.ondragstart = function() {
        return false
    }

</script>
</body>
</html>
